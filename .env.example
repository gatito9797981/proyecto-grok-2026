# Archivo de Configuración de Grok3API
# Copia este archivo como .env y ajusta los valores

# Tiempo máximo de espera para el navegador (en segundos)
TIMEOUT=360

# Proxy por defecto (déjalo vacío si no lo necesitas)
# Ejemplo: DEF_PROXY=socks4://98.178.72.21:10919
DEF_PROXY=

# Usar Xvfb en Linux (True/False)
USE_XVFB=True

# Anti-detección avanzada
# basic: solo spoofing esencial de navigator y canvas
# standard: spoofing de WebGL y AudioContext mejorado
# full: WebRTC leak prevention y font fingerprint protection
ANTI_DETECTION_LEVEL=full

# Fingerprint (opcional - se genera aleatoriamente si no se especifica)
# Esto permite tener consistencia entre sesiones si usas el mismo seed
# FINGERPRINT_SEED=123456

# Hardware spoofing (opcional - se usan valores realistas por defecto)
# HARDWARE_CONCURRENCY=8
# DEVICE_MEMORY=8
# PLATFORM=Win32
# VENDOR=Google Inc.
# MAX_TOUCH_POINTS=0
# MAX_TEXTURE_SIZE=16384
